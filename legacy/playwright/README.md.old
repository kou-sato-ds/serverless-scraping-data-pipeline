```json
{
  "fetched_at": "2026-05-08T09:00:12.345678+00:00",
  "source": "https://news.google.com",
  "count": 30,
  "articles": [
    {
      "title": "サンプルニュースタイトル",
      "link": "https://news.google.com/articles/CBMiSGh0dHBzOi8v..."
    },
    {
      "title": "別のニュース見出し",
      "link": "https://news.google.com/articles/CBMiP2h0dHBzOi8v..."
    }
  ]
}
```

